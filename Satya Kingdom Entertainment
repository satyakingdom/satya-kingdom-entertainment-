    <div class="services">
        <div class="card">
            <h3>DJ & Music</h3>
            <p>High quality DJ sound system</p>
        </div>

        <div class="card">
            <h3>Event Decoration</h3>
            <p>Beautiful decoration for all events</p>
        </div>

