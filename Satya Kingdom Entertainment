<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Satya Kingdom Entertainment</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
}

/* Header */
header {
    background: #000;
    color: #fff;
    padding: 15px;
    text-align: center;
}

/* Navbar */
nav {
    background: #ffcc00;
    padding: 10px;
    text-align: center;
}

nav a {
    color: black;
    margin: 15px;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    color: red;
}

/* Hero */
.hero {
    background: url('https://via.placeholder.com/1200x400') no-repeat center;
    background-size: cover;
    color: white;
    padding: 100px 20px;
    text-align: center;
}

.hero h1 {
    font-size: 40px;
}

/* Button */
.btn {
    background: red;
    padding: 12px 25px;
    color: white;
    border: none;
    cursor: pointer;
    border-radius: 5px;
}

.btn:hover {
    background: black;
}

/* Section */
section {
    padding: 40px;
    text-align: center;
}

/* Services */
.services {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
}

.card {
    border: 1px solid #ddd;
    padding: 20px;
    width: 250px;
    border-radius: 10px;
}

/* Footer */
footer {
    background: black;
    color: white;
    padding: 15px;
    text-align: center;
}
</style>
</head>

